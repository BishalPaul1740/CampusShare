<div class="container py-5">

    <h2 class="mb-4">

        Reservation Requests

    </h2>

    <% if (reservations.length === 0) { %>

        <div class="alert alert-info">

            No reservation requests received.

        </div>

    <% } else { %>

        <div class="row">

            <% reservations.forEach(reservation => { %>

                <div class="col-lg-6 mb-4">

                    <div class="card shadow-sm h-100">

                        <% if (reservation.resource && reservation.resource.images.length > 0) { %>

                            <img
                                src="<%= reservation.resource.images[0].url %>"
                                class="card-img-top"
                                style="height:220px; object-fit:cover;">

                        <% } %>

                        <div class="card-body">

                            <h4>

                                <%= reservation.resource ? reservation.resource.title : "Resource Deleted" %>

                            </h4>

                            <hr>

                            <p>

                                <strong>Borrower:</strong>

                                <%= reservation.borrower.name %>

                            </p>

                            <p>

                                <strong>Email:</strong>

                                <%= reservation.borrower.email %>

                            </p>

                            <p>

                                <strong>Location:</strong>

                                <%= reservation.resource ? reservation.resource.location : "-" %>

                            </p>

                            <p>

                                <strong>Start Date:</strong>

                                <%= reservation.startDate.toLocaleDateString() %>

                            </p>

                            <p>

                                <strong>End Date:</strong>

                                <%= reservation.endDate.toLocaleDateString() %>

                            </p>

                            <p>

                                <strong>Status:</strong>

                                <% if (reservation.status === "Pending") { %>

                                    <span class="badge bg-warning text-dark">

                                        Pending

                                    </span>

                                <% } else if (reservation.status === "Approved") { %>

                                    <span class="badge bg-success">

                                        Approved

                                    </span>

                                <% } else if (reservation.status === "Rejected") { %>

                                    <span class="badge bg-danger">

                                        Rejected

                                    </span>

                                <% } else if (reservation.status === "Cancelled") { %>

                                    <span class="badge bg-secondary">

                                        Cancelled

                                    </span>

                                <% } else { %>

                                    <span class="badge bg-primary">

                                        <%= reservation.status %>

                                    </span>

                                <% } %>

                            </p>

                            <div class="d-flex gap-2 mt-3">

                                <a
                                    href="/reservations/<%= reservation._id %>"
                                    class="btn btn-outline-primary">

                                    View

                                </a>

                                <% if (reservation.status === "Pending") { %>

                                    <button
                                        class="btn btn-success"
                                        disabled>

                                        Approve

                                    </button>

                                    <button
                                        class="btn btn-danger"
                                        disabled>

                                        Reject

                                    </button>

                                <% } %>

                            </div>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</div>