<div class="container py-5">

    <a
        href="/resources"
        class="btn btn-outline-secondary mb-4">

        ← Back to Resources

    </a>

    <div class="row">

        <div class="col-lg-6">

            <% if(resource.images.length > 0){ %>

                <% resource.images.forEach(image => { %>

                    <img
                        src="<%= image.url %>"
                        class="img-fluid rounded shadow mb-3"
                        alt="Resource Image">

                <% }) %>

            <% } else { %>

                <img
                    src="https://placehold.co/800x500?text=No+Image"
                    class="img-fluid rounded shadow">

            <% } %>

        </div>

        <div class="col-lg-6">

            <h2>

                <%= resource.title %>

            </h2>

            <hr>

            <p>

                <strong>Description:</strong>

                <br>

                <%= resource.description %>

            </p>

            <p>

                <strong>Category:</strong>

                <%= resource.category.name %>

            </p>

            <p>

                <strong>Owner:</strong>

                <%= resource.owner.name %>

            </p>

            <p>

                <strong>Email:</strong>

                <%= resource.owner.email %>

            </p>

            <p>

                <strong>Location:</strong>

                <%= resource.location %>

            </p>

            <p>

                <strong>Deposit:</strong>

                ₹ <%= resource.deposit %>

            </p>

            <p>

                <strong>Quantity:</strong>

                <%= resource.quantity %>

            </p>

            <p>

                <strong>Available Quantity:</strong>

                <%= resource.availableQuantity %>

            </p>

            <p>

                <strong>Condition:</strong>

                <%= resource.condition %>

            </p>

            <p>

                <strong>Status:</strong>

                <span class="badge bg-success">

                    <%= resource.availabilityStatus %>

                </span>

            </p>

            <% if(resource.tags.length > 0){ %>

                <div class="mb-3">

                    <strong>Tags:</strong>

                    <br>

                    <% resource.tags.forEach(tag => { %>

                        <span class="badge bg-secondary me-1">

                            <%= tag %>

                        </span>

                    <% }) %>

                </div>

            <% } %>

            <div class="d-flex gap-2 mt-4">

                <a
                    href="/resources"
                    class="btn btn-secondary">

                    Back

                </a>

                <% if (user && resource.owner._id.toString() === user._id.toString()) { %>

                    <a
                                            href="/resources/<%= resource._id %>/edit"
                                            class="btn btn-warning">

                                            Edit Resource

                                        </a>

                                    <% } else { %>

                                        <a
                        href="/resources/<%= resource._id %>/reserve"
                        class="btn btn-primary">

                        Reserve Resource

                    </a>

                <% } %>

            </div>

        </div>

    </div>

</div>