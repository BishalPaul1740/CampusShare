<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>

            Campus Resources

        </h2>
        <form
            action="/resources"
            method="GET"
            class="row g-3 mb-4">

            <!-- Search -->

            <div class="col-md-4">

                <input
                    type="text"
                    class="form-control"
                    name="search"
                    placeholder="Search resources..."
                    value="<%= search %>">

            </div>

            <!-- Category -->

            <div class="col-md-3">

                <select
                    name="category"
                    class="form-select">

                    <option value="">All Categories</option>

                    <% categories.forEach(category => { %>

                        <option
                            value="<%= category.name %>"
                            <%= selectedCategory===category.name ? "selected" : "" %>>

                            <%= category.name %>

                        </option>

                    <% }) %>

                </select>

            </div>

            <!-- Availability -->

            <div class="col-md-3">

                <select
                    name="availability"
                    class="form-select">

                    <option value="">All Availability</option>

                    <option
                        value="Available"
                        <%= selectedAvailability==="Available" ? "selected" : "" %>>

                        Available

                    </option>

                    <option
                        value="Reserved"
                        <%= selectedAvailability==="Reserved" ? "selected" : "" %>>

                        Reserved

                    </option>

                    <option
                        value="Unavailable"
                        <%= selectedAvailability==="Unavailable" ? "selected" : "" %>>

                        Unavailable

                    </option>

                </select>

            </div>

            <!-- Buttons -->

            <div class="col-md-1 d-grid">

                <button
                    class="btn btn-primary">

                    Search

                </button>

            </div>

            <div class="col-md-1 d-grid">

                <a
                    href="/resources"
                    class="btn btn-outline-secondary">

                    Clear

                </a>

            </div>
            <div class="col-md-3">

                <select
                    name="sort"
                    class="form-select">

                    <option value="">Newest First</option>

                    <option
                        value="oldest"
                        <%= selectedSort==="oldest" ? "selected" : "" %>>
                        Oldest First
                    </option>

                    <option
                        value="titleAsc"
                        <%= selectedSort==="titleAsc" ? "selected" : "" %>>
                        Title (A–Z)
                    </option>

                    <option
                        value="titleDesc"
                        <%= selectedSort==="titleDesc" ? "selected" : "" %>>
                        Title (Z–A)
                    </option>

                    <option
                        value="depositAsc"
                        <%= selectedSort==="depositAsc" ? "selected" : "" %>>
                        Lowest Deposit
                    </option>

                    <option
                        value="depositDesc"
                        <%= selectedSort==="depositDesc" ? "selected" : "" %>>
                        Highest Deposit
                    </option>

                </select>

            </div>

        </form>
        <a
            href="/resources/new"
            class="btn btn-success">

            <i class="bi bi-plus-circle"></i>

            Create Resource

        </a>
    </div>

    <% if(resources.length === 0){ %>

        <div class="alert alert-info">

            No resources available.

        </div>

    <% } else { %>

        <div class="row g-4">

            <% resources.forEach(resource => { %>

                <div class="col-md-6 col-lg-4">

                    <div class="card h-100 shadow-sm">

                        <% if(resource.images.length > 0){ %>

                            <img
                                src="<%= resource.images[0].url %>"
                                class="card-img-top"
                                style="height:220px; object-fit:cover;">

                        <% } else { %>

                            <img
                                src="https://placehold.co/600x400?text=No+Image"
                                class="card-img-top">

                        <% } %>

                        <div class="card-body">

                            <h5 class="card-title">

                                <%= resource.title %>

                            </h5>

                            <p>

                                <strong>Category:</strong>

                                <%= resource.category.name %>

                            </p>

                            <p>

                                <strong>Owner:</strong>

                                <%= resource.owner.name %>

                            </p>

                            <p>

                                <strong>Location:</strong>

                                <%= resource.location %>

                            </p>

                            <p>

                                <strong>Status:</strong>

                                <span class="badge bg-success">

                                    <%= resource.availabilityStatus %>

                                </span>

                            </p>

                            <div class="mt-3">

                                <a
                                    href="/resources/<%= resource._id %>"
                                    class="btn btn-primary w-100">

                                    View Details

                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>
        <% if (totalPages > 1) { %>

            <nav class="mt-4">

                <ul class="pagination justify-content-center">

                    <!-- Previous -->

                    <li class="page-item <%= currentPageNumber === 1 ? 'disabled' : '' %>">

                        <a
                            class="page-link"
                            href="?<%= new URLSearchParams({ ...query, page: currentPageNumber - 1 }).toString() %>">

                            Previous

                        </a>

                    </li>

                    <!-- Page Numbers -->

                    <% for(let i = 1; i <= totalPages; i++) { %>

                        <li class="page-item <%= currentPageNumber === i ? 'active' : '' %>">

                            <a
                                class="page-link"
                                href="?<%= new URLSearchParams({ ...query, page: i }).toString() %>">

                                <%= i %>

                            </a>

                        </li>

                    <% } %>

                    <!-- Next -->

                    <li class="page-item <%= currentPageNumber === totalPages ? 'disabled' : '' %>">

                        <a
                            class="page-link"
                            href="?<%= new URLSearchParams({ ...query, page: currentPageNumber + 1 }).toString() %>">

                            Next

                        </a>

                    </li>

                </ul>

            </nav>

            <% } %>

    <% } %>

</div>